{
  "skill_name": "skill-review",
  "version": "1.1.0",
  "created": "2026-05-29",
  "last_updated": "2026-06-09",
  "evals": [
    {
      "id": 1,
      "prompt": "/skill-review 示例-代码审查skill",
      "description": "审查代码审查 skill 示例",
      "expected_output": "安全审查 + 10 维度评分报告，包含安全评级、总分、评级、亮点、问题与建议",
      "assertions": [
        { "id": "a1", "text": "报告包含安全审查部分（安全评级、风险标记、权限范围）" },
        { "id": "a2", "text": "报告包含 10 个维度的评分表格" },
        { "id": "a3", "text": "每个维度有得分、满分、评级" },
        { "id": "a4", "text": "包含综合评级（强烈推荐/值得一试/仍需改进）" },
        { "id": "a5", "text": "包含亮点列表" },
        { "id": "a6", "text": "包含问题与建议" },
        { "id": "a7", "text": "包含审查统计" }
      ]
    },
    {
      "id": 2,
      "prompt": "/skill-review skill-dev",
      "description": "审查 skill-dev 元技能",
      "expected_output": "10 维度评分报告",
      "assertions": [
        { "id": "a1", "text": "能正确找到全局skills目录中的 skill-dev/ 或工作区中的 skill-dev/" },
        { "id": "a2", "text": "能读取 SKILL.md 和 references/ 目录" },
        { "id": "a3", "text": "输出格式与示例一致" }
      ]
    },
    {
      "id": 3,
      "prompt": "/skill-review nonexistent-skill",
      "description": "审查不存在的 skill",
      "expected_output": "错误提示：Skill 目录不存在",
      "assertions": [
        { "id": "a1", "text": "不崩溃，正常输出错误信息" },
        { "id": "a2", "text": "提示用户检查路径" }
      ]
    },
    {
      "id": 4,
      "prompt": "帮我看看这个skill的质量",
      "description": "自然语言触发审查",
      "expected_output": "询问用户要审查哪个 skill",
      "assertions": [
        { "id": "a1", "text": "识别为审查请求" },
        { "id": "a2", "text": "要求用户提供 skill 路径或名称" }
      ]
    },
    {
      "id": 5,
      "prompt": "帮我开发一个新skill",
      "description": "反例：不应触发审查",
      "expected_output": "不触发 skill-review，应该触发 skill-dev",
      "assertions": [
        { "id": "a1", "text": "不触发 skill-review" }
      ]
    }
  ]
}
